{
  "family": "xrestaurant-backend-postgres",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/xrestaurant-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/xrestaurant-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "xrestaurant-backend",
      "image": "ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/xrestaurant-backend:postgres-v1",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "AWS_REGION",
          "value": "ap-southeast-1"
        },
        {
          "name": "DB_USE_POSTGRES",
          "value": "true"
        },
        {
          "name": "DB_SECRET_NAME",
          "value": "xrestaurant/rds/credentials"
        },
        {
          "name": "DB_SSL",
          "value": "true"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        },
        {
          "name": "CLOUDWATCH_LOG_GROUP",
          "value": "/aws/ecs/xrestaurant-backend"
        }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/xrestaurant-backend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "postgres"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "stopTimeout": 30,
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ]
    }
  ],
  "tags": [
    {
      "key": "Name",
      "value": "xrestaurant-backend-postgres"
    },
    {
      "key": "Environment",
      "value": "production"
    },
    {
      "key": "Database",
      "value": "PostgreSQL"
    }
  ]
}
